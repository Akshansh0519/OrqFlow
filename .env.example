# ─────────────────────────────────────────────────────────────────────────────
# OrqFlow — Environment Variables
# Copy this to .env and fill in the blanks. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Local Docker: postgresql+asyncpg://postgres:password@postgres:5432/orqflow
# Production (e.g. Render Postgres): use the provided connection string, replace
# the scheme prefix with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/orqflow
# Production: separate readonly connection for the MCP DB tool server.
MCP_DATABASE_URL=postgresql+asyncpg://orqflow_readonly:readonly_pass@postgres:5432/orqflow

# ── Redis ────────────────────────────────────────────────────────────────────
# Local Docker:  redis://redis:6379
# Upstash:       rediss://:<password>@<host>:6379  (note: rediss:// with SSL)
# Redis Cloud:   redis://:<password>@<host>:<port>
REDIS_URL=redis://redis:6379

# ── JWT Secrets (REQUIRED — min 32 random characters each, must be different) ─
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No trailing slash.
# Local dev:   http://localhost:5173
# Production:  https://orqflow.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173

# ── MCP Server Auth (shared bearer key, read by all 4 services) ──────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_SERVER_KEY=

# ── MCP Server URLs (override per environment) ───────────────────────────────
# Docker Compose (default — service name DNS resolution):
MCP_DB_URL=http://mcp-db:8001/mcp
MCP_SEARCH_URL=http://mcp-search:8002/mcp
MCP_FILES_URL=http://mcp-files:8003/mcp
# Production: replace with actual deployed URLs if MCP servers are separate services

# ── Search Provider ───────────────────────────────────────────────────────────
# "tavily" = real Tavily API (requires TAVILY_API_KEY)
# "mock"   = deterministic offline fixture (for tests and offline dev)
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# ── LLM Models (see prep/cards/card-09-model-tiering.md) ─────────────────────
# ROUTER_LLM_MODEL: stronger model — supervisor routing + final synthesis
# WORKER_LLM_MODEL: cheaper model — specialist tool-calling loops
ROUTER_LLM_MODEL=claude-sonnet-4-5-20250514
WORKER_LLM_MODEL=claude-haiku-3-5-20241022
ANTHROPIC_API_KEY=

# ── Deployment (set these in Render/Railway/Fly dashboard, not in local .env) ─
# PORT: platform sets this automatically. DO NOT hardcode in Dockerfile CMD.
# PORT=8000

# API_BASE_URL: used for Swagger UI "servers" config so "Try it out" works on
# the deployed site. Leave blank for local dev (defaults to relative URLs).
# API_BASE_URL=https://orqflow.onrender.com
ENVIRONMENT=development

# Frontend build-time variable. Set this in Vercel/Netlify/etc. for production.
# VITE_API_BASE_URL=https://orqflow.onrender.com

# ── Redis Resilience (auto-detected from REDIS_URL, but overridable) ─────────
# REDIS_SOCKET_TIMEOUT: seconds before a stalled Redis call is abandoned.
# Default 5 — prevents infinite hanging on free-tier drops.
REDIS_SOCKET_TIMEOUT=5
